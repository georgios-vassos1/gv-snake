# ── CMake out-of-source build directories ─────────────────────────────────────
build/
cmake-build-*/

# ── Generated CMake / make artefacts (in-source build safety net) ─────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
_deps/

# ── Compiled objects and libraries ────────────────────────────────────────────
*.o
*.a
*.so
*.dylib

# ── Executables ───────────────────────────────────────────────────────────────
snake
*.exe
*.bin
*.out

# ── Crash dumps ───────────────────────────────────────────────────────────────
*.stackdump
*.dSYM/

# ── macOS metadata ────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
*.xcodeproj/
*.xcworkspace/
